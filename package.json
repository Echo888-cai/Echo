{
  "name": "echo-research",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "An evidence-first AI research desk for public-market investors.",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "node server.js",
    "seed": "node scripts/seed-db.js",
    "test": "npm run build:native && node tests/run.mjs && npm test --workspace @echo/domain && npm test --workspace @echo/db && npm test --workspace @echo/api && npm test --workspace @echo/finance-native && cargo test --workspace",
    "test:rust": "cargo test --workspace",
    "build:native": "npm run build --workspace @echo/finance-native",
    "lint:rust": "cargo fmt --all --check && cargo clippy --workspace --all-targets -- -D warnings",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit -p jsconfig.json",
    "typecheck:workspaces": "npm run typecheck --workspaces --if-present",
    "doctor": "node scripts/doctor.js",
    "doctor:prod": "node scripts/doctor.js --production",
    "canary": "node scripts/canary.js",
    "factguard-sample": "node scripts/factguard-sample.js",
    "coverage:hk": "node scripts/coverage.js --market=hk",
    "coverage:cn": "node scripts/coverage.js --market=cn"
  },
  "dependencies": {
    "@echo/domain": "*",
    "@echo/finance-native": "*",
    "better-sqlite3": "^12.11.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  }
}
