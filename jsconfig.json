{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "strict": false,
    "skipLibCheck": true,
    "maxNodeModuleJsDepth": 0,
    "noEmit": true
  },
  "include": ["src/**/*.js", "server.js"],
  "exclude": ["node_modules", "tests"]
}
