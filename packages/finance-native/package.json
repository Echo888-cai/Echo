{
  "name": "@echo/finance-native",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "N-API boundary for the deterministic Echo Rust finance kernel.",
  "main": "./index.cjs",
  "types": "./index.d.ts",
  "files": ["index.cjs", "index.d.ts", "*.node"],
  "scripts": {
    "build": "napi build --platform --release --js index.cjs --dts index.d.ts --no-dts-header",
    "test": "node --test test.mjs",
    "typecheck": "tsc --noEmit --allowJs --checkJs false index.cjs"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.3",
    "typescript": "^6.0.3"
  },
  "napi": {
    "binaryName": "echo-finance-native",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-gnu"
    ]
  }
}
