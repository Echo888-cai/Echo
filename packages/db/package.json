{
  "name": "@echo/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "PostgreSQL schema, SQL migrations, RLS and Drizzle repositories for Echo Research.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./repositories/*": "./src/repositories/*"
  },
  "scripts": {
    "migrate": "tsx src/migrate.ts",
    "test": "tsx --test src/architecture.test.ts && tsx src/rls.integration.test.ts && tsx --test src/repositories/repositories.integration.test.ts",
    "test:postgres": "tsx src/rls.integration.test.ts",
    "test:repositories": "tsx --test src/repositories/repositories.integration.test.ts",
    "drill:recovery": "tsx src/recovery-drill.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"
  }
}
