# Echo Research 生产反代（U-3 / E14，PLAN v5）。
# Caddy 自动签发/续期 Let's Encrypt 证书；Node 进程继续只绑 127.0.0.1（红线 19），
# 对外的只有 Caddy。把 research.example.com 换成你的域名。

research.example.com {
    reverse_proxy 127.0.0.1:4173 {
        # SSE 流式回答：禁用缓冲，token 边到边发
        flush_interval -1
    }

    encode gzip

    header {
        # 内测阶段不希望被搜索引擎收录（红线 17：不公开宣传）
        X-Robots-Tag "noindex, nofollow"
        Strict-Transport-Security "max-age=15552000"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "same-origin"
        # 图表/估值条用数据驱动的 inline style 定位；仅 style 放开 inline，script 仍严格 self。
        Content-Security-Policy "default-src 'self'; connect-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; base-uri 'none'; frame-ancestors 'none'; form-action 'self'"
        Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
        -Server
    }

    log {
        output file /var/log/caddy/echo-research.log {
            roll_size 20mb
            roll_keep 5
        }
    }
}
