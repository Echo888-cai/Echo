# 模型
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# 如果用 DeepSeek 做分析 Agent，优先填写这两个
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro

# 行情源（港美股）。任意一个即可；港股优先用免费 Tencent Finance，美股走 Finnhub/Alpha Vantage/Yahoo。
ALPHAVANTAGE_API_KEY=
TWELVEDATA_API_KEY=
FINNHUB_API_KEY=

# 财务数据源（FMP，新版 /stable 接口）。免费档覆盖【美股】真实 EPS/FCF/利润率
# → 美股利润质量评分与估值真实分化；港股完整三表需 FMP 付费档或其它港股数据源。
FMP_API_KEY=

# 新闻增强（设为 1 启用 Google News RSS）
LUVIO_ENABLE_GOOGLE_NEWS=

# 网页证据层（推荐至少配置一个，用于自动搜索公开资料并缓存到 SQLite）
TAVILY_API_KEY=
SERPAPI_API_KEY=

# SEC EDGAR 礼貌头（一手文件抓取用，格式："你的名字 you@example.com"）
SEC_USER_AGENT=

# 通知推送（可选）。不配也有 Web 内通知中心；配了才能推到手机。
# 1) Telegram 搜 @BotFather → /newbot → 拿 token
# 2) 给你的 bot 发一条消息，然后浏览器打开
#    https://api.telegram.org/bot<你的token>/getUpdates 取 message.chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 设为 1 可禁用进程内定时任务（盘前速报/持仓触线巡检）；CI/测试环境用
LUVIO_DISABLE_SCHEDULER=
