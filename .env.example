# Runtime
API_HOST=127.0.0.1
API_PORT=4180
DATABASE_URL=
# Optional read-replica connection string; unset falls back to DATABASE_URL.
DATABASE_URL_READ=
TEMPORAL_ADDRESS=127.0.0.1:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=echo-research
# Temporal Cloud only; leave unset for a local server.
TEMPORAL_API_KEY=
TEMPORAL_TLS=0
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_HEADERS=

# Model gateway (first configured provider wins: DeepSeek, OpenAI, generic OpenAI-compatible)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
MODEL_API_KEY=
MODEL_NAME=
MODEL_BASE_URL=

# Market and fundamentals data
ALPHAVANTAGE_API_KEY=
TWELVEDATA_API_KEY=
FINNHUB_API_KEY=
FMP_API_KEY=

# Evidence and filings
TAVILY_API_KEY=

# Authentication and tenancy
ECHO_TRUST_PROXY=0
ECHO_AUTH_DISABLED=0

# Model usage display on the settings page (not yet enforced in the call path).
ECHO_DAILY_MODEL_CALLS=40
ECHO_OWNER_DAILY_MODEL_CALLS=40
ECHO_DAILY_COST_USD=0

# Scheduler and backups. Unset bucket keeps dumps on local disk only.
ECHO_DISABLE_SCHEDULER=0
ECHO_BACKUP_DIR=
ECHO_BACKUP_BUCKET=
AWS_REGION=ap-east-1

# Number verification: off | shadow | soft | full
FACT_GUARD_MODE=full
