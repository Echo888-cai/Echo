# 模型
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# 如果用 DeepSeek 做分析 Agent，优先填写这两个
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro

# 行情源（港美股）。任意一个即可；港股优先用免费 Tencent Finance，美股走 Finnhub/Alpha Vantage/Yahoo。
ALPHAVANTAGE_API_KEY=
TWELVEDATA_API_KEY=
FINNHUB_API_KEY=

# 财务数据源（FMP，新版 /stable 接口）。免费档覆盖【美股】真实 EPS/FCF/利润率
# → 美股利润质量评分与估值真实分化；港股完整三表需 FMP 付费档或其它港股数据源。
FMP_API_KEY=

# 新闻增强（设为 1 启用 Google News RSS）
LUVIO_ENABLE_GOOGLE_NEWS=

# 网页证据层（推荐至少配置一个，用于自动搜索公开资料并缓存到 SQLite）
TAVILY_API_KEY=
SERPAPI_API_KEY=

# SEC EDGAR 礼貌头（一手文件抓取用，格式："你的名字 you@example.com"）
SEC_USER_AGENT=

# 通知推送（可选）。不配也有 Web 内通知中心；配了才能推到手机。
# 1) Telegram 搜 @BotFather → /newbot → 拿 token
# 2) 给你的 bot 发一条消息，然后浏览器打开
#    https://api.telegram.org/bot<你的token>/getUpdates 取 message.chat.id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# 设为 1 可禁用进程内定时任务（盘前速报/持仓触线巡检）；CI/测试环境用
LUVIO_DISABLE_SCHEDULER=

# R3 数字级防幻觉护栏：shadow（默认，只打日志不改输出）| soft（追加低调提示，不拦截）
# | full（hard-fail 触发一次定向重答，仍不过就确定性降级）| off（完全关闭）。
# 按方案分阶段推进：先用 scripts/factguard-sample.js 跑真实问题看 shadow 日志调阈值，
# 确认误报率可接受再依次开 soft → full，不要一次性跳到 full。
FACT_GUARD_MODE=shadow

# E10 研究成本汇总（可选）：设置页"模型调用"卡片按这里的价格把真实 token 用量折算成美元。
# 单位 USD / 1M tokens（跟各家账单的报价粒度一致，直接抄账单数字即可）。不配置就只显示
# token 用量，不猜一个可能过期的价格——provider 名要大写，对应 modelGateway.js 的 provider.id。
# LLM_PRICE_DEEPSEEK_INPUT=
# LLM_PRICE_DEEPSEEK_OUTPUT=
# LLM_PRICE_OPENAI_INPUT=
# LLM_PRICE_OPENAI_OUTPUT=
# LLM_PRICE_GLM_INPUT=
# LLM_PRICE_GLM_OUTPUT=
