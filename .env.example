# Runtime
ECHO_BASE_URL=http://127.0.0.1:4173
PORT=4173
ECHO_DB_PATH=
DATABASE_URL=

# Model gateway (first configured provider wins: GLM, DeepSeek, OpenAI, generic)
GLM_API_KEY=
GLM_MODEL=
GLM_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=
MODEL_API_KEY=
MODEL_MODEL=
MODEL_BASE_URL=

# Market and fundamentals data
# Massive (formerly Polygon.io): preferred US quote source when configured.
MASSIVE_API_KEY=
# Set only after a signed commercial/display license, not merely after buying an individual plan.
ECHO_MASSIVE_COMMERCIAL_LICENSE=0
ALPHAVANTAGE_API_KEY=
TWELVEDATA_API_KEY=
FINNHUB_API_KEY=
EODHD_API_KEY=
FMP_API_KEY=
# Optional comma-separated key pool used before FMP_API_KEY.
FMP_API_KEYS=
# Production must explicitly declare that every selected source is commercially licensed.
ECHO_COMMERCIAL_DATA=0

# Evidence and filings
ECHO_ENABLE_GOOGLE_NEWS=0
TAVILY_API_KEY=
SERPAPI_API_KEY=
SEC_USER_AGENT=Echo Research your-real-contact@example.com

# Notifications
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Authentication, tenancy and rate limiting
ECHO_TRUST_PROXY=0
ECHO_AUTH_DISABLED=0
ECHO_RATE_LIMIT_DISABLED=0
ECHO_RATE_GENERAL_PER_MIN=240
ECHO_RATE_HEAVY_PER_MIN=12
ECHO_BETA_MODE=1

# Model budgets. Zero cost limit means disabled until explicit pricing is configured.
ECHO_DAILY_MODEL_CALLS=40
ECHO_OWNER_DAILY_MODEL_CALLS=40
ECHO_DAILY_COST_USD=0
ECHO_INPUT_USD_PER_M_TOKENS=0
ECHO_OUTPUT_USD_PER_M_TOKENS=0

# Scheduler and backups
ECHO_DISABLE_SCHEDULER=0
ECHO_BACKUP_DIR=
# Example: rclone copy {file} remote:echo-backups/
ECHO_BACKUP_PUSH_CMD=

# Number verification: off | shadow | soft | full
FACT_GUARD_MODE=full
