# HTTP
API_HOST=0.0.0.0
API_PORT=4180
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/echo_dev
DATABASE_MAX_CONNECTIONS=5

# 本地单用户开发可打开；生产必须关闭并使用邀请码注册。
ECHO_AUTH_DISABLED=0
ECHO_AUTH_DISABLED_USER_ID=local
ECHO_TRUST_PROXY=0

# 状态变更请求的 Origin 白名单（逗号分隔）；缺省即本地 Trunk 开发代理来源，生产必须显式覆盖。
ECHO_ALLOWED_ORIGINS=http://localhost:5190
# /api/ask、/api/ask/stream 每用户每分钟配额（共享一个滑动窗口）。
ECHO_ASK_RATE_LIMIT_PER_MINUTE=20

# OTLP 追踪导出（echo-api/echo-worker 共用，echo-observability::init 消费）：标准 OTel
# 环境变量名，值形如 http://localhost:4318（明文 HTTP，收集端通常是同网/同机 sidecar；
# HTTPS 收集端需要额外 TLS 后端，本仓库暂不支持）。留空则完全不初始化 OTLP（不后台起
# 任何导出线程），stdout 日志（RUST_LOG/ECHO_LOG_FORMAT）不受影响。
OTEL_EXPORTER_OTLP_ENDPOINT=

# 模型网关（服务端读取）：DeepSeek 具名预设优先；未配则退到通用 MODEL_* 覆盖层
# （指向任意 OpenAI 兼容端点，含 OpenAI 本身，需同时给 MODEL_API_KEY 与 MODEL_BASE_URL）。
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
MODEL_API_KEY=
MODEL_NAME=
MODEL_BASE_URL=

# 外部数据源（免费源默认只允许研究模式）
FINNHUB_API_KEY=
FMP_API_KEY=
# 网页证据供应商（consumer: echo-data::EvidenceService）——双供应商可切换：配了 EXA_API_KEY
# 优先走 Exa（语义检索，有可用月度免费额度），否则回落 TAVILY_API_KEY。只对定性、时效敏感的
# 意图（现状/护城河/竞争/风险/证伪/深研）拉取；有 DATABASE_URL 时按供应商+检索式落
# web_evidence 24h 缓存，无库走实时。未配/额度耗尽且无缓存则诚实降级为"本轮无网页证据、
# 置信度下降"。免费/研究档不算商用授权，故 ECHO_COMMERCIAL_MODE=1 时证据端口自行拒绝。
EXA_API_KEY=
TAVILY_API_KEY=
ECHO_COMMERCIAL_MODE=0

# Worker
WORKER_TICK_SECONDS=60

# 简报邮件（echo-worker 消费）：SMTP_HOST/USER/PASS 三项均非空才启用；未配置时
# 盘前/盘后简报仍写入站内通知面板，只是不发邮件（诚实降级，见 echo-config::EmailConfig）。
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
