{
  "name": "@echo/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "R-2: NestJS application layer that fronts the existing src/server/services|repositories domain logic. Parallel entry point to server.js (not a replacement yet).",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "tsx src/main.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts"
  },
  "dependencies": {
    "@echo/contracts": "*",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^26.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
